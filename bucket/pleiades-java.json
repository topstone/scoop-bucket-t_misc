{
    "version": "20260117",
    "description": "Eclipse IDE for Java Developers (Pleiades All in One)",
    "homepage": "https://willbrains.jp/",
    "license": "EPL-1.0",
    "architecture": {
        "64bit": {
            "url": "https://ftp.jaist.ac.jp/pub/mergedoc/pleiades/2025/pleiades-2025-12-java-win-64bit-jre_20260117.exe",
            "hash": "sha512:b2afc24b06c10d8e650e1dd8e0748dcf7ad0c1c8a104c26ef112735c76a43ade0c56bfde827cfdcbe887d60a05d37d546a5a32440450a57719109d26fd647b36"
        }
    },
    "pre_install": [
        "$exe = \"$dir\\pleiades-$matchYear-$matchMonth-java-win-64bit-jre_$version.exe\"",
        "if (Test-Path \"$exe\") {",
        "    Invoke-Expression \"7z x `\"$exe`\" -o`\"$dir`\" -y | Out-Null\"",
        "    Remove-Item \"$exe\"",
        "}",
        "Get-ChildItem \"$dir\" -Filter \"pleiades-*\" -Directory | Remove-Item -Recurse -Force"
    ],
    "shortcuts": [
        [
            "eclipse\\eclipse.exe",
            "Eclipse (Pleiades) for Java Developers"
        ]
    ],
    "checkver": {
        "url": "https://willbrains.jp/pleiades.html?v=4",
        "regex": "pleiades-([\\d]{4})-([\\d]{2})-java-win-64bit-jre_([\\d]{8})\\.exe",
        "replace": "${3}",
        "reverse": true
    }
}
